# Copy this file to .env and fill in the values before running docker-compose.
# NEVER commit the .env file to version control.

# ─── JWT ────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters (256 bits for HS256).
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_AUTH_USER=authuser
POSTGRES_AUTH_PASSWORD=

POSTGRES_USER_USER=useruser
POSTGRES_USER_PASSWORD=

POSTGRES_MESSAGE_USER=messageuser
POSTGRES_MESSAGE_PASSWORD=

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=orangchat
RABBITMQ_PASSWORD=

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# ─── CORS (WebSocket allowed origins, comma-separated) ───────────────────────
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
